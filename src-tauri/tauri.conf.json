{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FLIP",
  "version": "0.1.0",
  "identifier": "com.miguelflor.flip",
  "build": {
    "frontendDist": "../vue-app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd vue-app && npm run dev",
    "beforeBuildCommand": "cd vue-app && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FLIP",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
